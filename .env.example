NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — enables GET /migrate to apply pending DB migrations.
# SUPABASE_DB_URL: Postgres connection string (Supabase → Settings → Database;
# use the Transaction pooler URI on serverless hosts).
# MIGRATE_TOKEN: any long random string; required as ?token= on /migrate.
SUPABASE_DB_URL=
MIGRATE_TOKEN=
